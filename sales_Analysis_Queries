# 7) What is the geographic and title-wise distribution of employees
WITH geoWiseDistribution AS (
    SELECT Country,
           City,
           COUNT(EmployeeID) AS TotalEmployee
    FROM Employees
    GROUP BY Country, City
)
SELECT * FROM geoWiseDistribution;

WITH Title_wise AS (
    SELECT Title,
           COUNT(EmployeeID) AS TotalEmployee
    FROM Employees
    GROUP BY Title
)
SELECT * FROM Title_wise;

# 8) What trends can we observe in hire dates across employee titles
# Ans 8) first we count the number of employee with hiring year and titles wise employee
