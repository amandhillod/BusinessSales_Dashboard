# Q1 What is the average number of orders per customer?
# Ans 1) I have count the number of the order with each customer and also count number of the order by country in the same Question 

with CountOrder as (
select CustomerID,shipCountry,
Count(OrderID) as OrderCount
from orders
group by CustomerID,shipCountry
)
select CustomerID,shipCountry,
Avg(OrderCount) as AvgOrderCount
from CountOrder
group by CustomerId,shipCountry;


# Q2 How do customer order patterns vary by city or country?
# Ans 2) Calculate Average Orders per City , By Country , order Frequency 

with OrderByGeography as (
select ShipCountry,
shipCity,
count(OrderId) as OrderCount
from orders
group by shipCountry,shipCity
)
select shipCountry,
shipCity,
OrderCount,
Avg(OrderCount) as OrderFrequency
from OrderByGeography
group by shipCountry,shipCity;

#Q3 Can we cluster customers based on total spend, order count, and preferred categories?

select distinct (o.CustomerID),
c.CategoryName as Preferred_Category,
Sum(od.UnitPrice * od.Quantity) as TotalSpend,
count(od.orderID) as orderCount
from orders o 
join order_details od on o.orderID = od.orderID
join products p on od.productID = p.productID
join categories c on p.CategoryID = c.categoryID
group by o.CustomerID,c.CategoryName; 

#Q4 Which product categories or products contribute most to order revenue? 
select ProductID,
productName,
sum(UnitPrice  * UnitsInStock) as Order_Revenue
from products
group by ProductID,productName;

#Q5 Are there any correlations between orders and customer location or product category?
select c.Address as Customer_Location,
p.productName as Product_Category,
sum(p.UnitPrice * p.UnitsInStock) as OrderRevenue
from  products p 
join order_details od on p.productID = od.productID
join orders o on od.orderID = o.orderID
join customers c on o.customerID = c.customerID
group by Customer_Location,Product_Category; 

