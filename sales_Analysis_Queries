#10)Are there correlations between product pricing, stock levels, and sales performance?

select ProductID,
UnitPrice as Product_Pricing,
UnitsInStock as Stock_Levels,
Sum(UnitPrice * UnitsInStock) as Sales
from Products
group by ProductID,UnitPrice,UnitsInStock;


# 11) How does product demand change over months or seasons?

select quarter(o.OrderDate) as Seasons,
Month(o.OrderDate) as Months,
sum(od.UnitPrice * od.Quantity) as DemandSales
from orders o
join order_details od on o.orderID = od.orderID
group by quarter(o.OrderDate),Month(o.OrderDate)
order by quarter(o.OrderDate),Month(o.OrderDate);

